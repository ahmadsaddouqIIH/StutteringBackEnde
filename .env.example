# Copy to `.env` and adjust. No real secrets — replace placeholders locally.

# Model artifact (file path for MODEL_SOURCE=local; cache/key hint for S3 workflows)
MODEL_PATH=models/example.pt

# local | s3 (S3 loading is stubbed unless you extend ModelService)
MODEL_SOURCE=local

# cpu | cuda
DEVICE=cpu

# Max upload size for POST /predict (MB)
MAX_AUDIO_SIZE_MB=10

# CORS: comma-separated or JSON list, e.g. http://localhost:3000,http://127.0.0.1:3000
# In production (PRODUCTION_MODE=true), "*" is rejected at startup.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# true = production safeguards (strict model path, no CORS "*", hide error details)
PRODUCTION_MODE=false

# Database URL (placeholder — use your real connection string in `.env` only)
DB_URL=postgresql://app_user:CHANGE_ME@localhost:5432/stuttering_ai

# API/service version exposed in OpenAPI and GET /health
SERVICE_VERSION=0.1.0

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
